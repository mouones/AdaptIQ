# --- PostgreSQL ---
POSTGRES_USER=adaptiq
POSTGRES_PASSWORD=change_this_postgres_password
POSTGRES_DB=adaptiq_db
DATABASE_URL=postgresql+asyncpg://adaptiq:change_this_postgres_password@localhost:5433/adaptiq_db

# --- Redis ---
REDIS_PASSWORD=change_this_redis_password
REDIS_URL=redis://:change_this_redis_password@localhost:6379/0

# --- JWT ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_this_to_a_random_32plus_character_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_BOOTSTRAP_KEY=change_this_admin_bootstrap_key

# --- LLM ---
GROQ_API_KEY=

# --- SMTP / OTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AdaptIQ
SMTP_USE_TLS=true

OTP_LENGTH=6
OTP_EXPIRE_SECONDS=300
OTP_MAX_ATTEMPTS=3

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO
AUTO_CREATE_TABLES=false
ENABLE_TRUSTWORTHY_GENERATION=false
ENABLE_PUBLIC_DOCS=true
ENABLE_DETAILED_ERRORS=true

# --- CORS ---
# Comma-separated origins, example: http://localhost:3000,http://localhost:5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Quiz Rules ---
QUIZ_TIME_LIMIT_SECONDS=30
QUIZ_QUESTIONS_PER_SESSION=10
CLASSIC_QUESTIONS_PER_SESSION=10
VISUAL_QUESTIONS_PER_SESSION=10
PVP_QUESTIONS_PER_MATCH=5
PVP_CANDIDATE_POOL_SIZE=100
POINTS_BASE_AWARD=10
POINTS_TIME_BONUS_DIVISOR=3
POINTS_HINT_PENALTY=3
POINTS_WRONG_PENALTY=5
ADMIN_DB_INSPECTOR_DEFAULT_LIMIT=100
ADMIN_DB_INSPECTOR_MAX_LIMIT=500
DATA_REPAIR_BATCH_SIZE=1000
CLEANUP_USER_BATCH_SIZE=1000

# --- Custom Room ---
# true = non-adaptive topic-practice mode (fixed difficulty, direct generation)
CUSTOM_ROOM_SIMPLE_MODE=false
CUSTOM_ROOM_FACTS_PER_TOPIC=1000
CUSTOM_ROOM_GENERATION_TARGET=1
CUSTOM_ROOM_RECENT_QUESTION_LIMIT=20
CUSTOM_ROOM_SESSION_TTL=3600

# --- Challenge Room ---
CHALLENGE_POINTS_LEVEL_1=3:-1
CHALLENGE_POINTS_LEVEL_2=5:-2
CHALLENGE_POINTS_LEVEL_3=7:-4
CHALLENGE_POINTS_LEVEL_4=9:-6
CHALLENGE_POINTS_LEVEL_5=11:-9

CHALLENGE_STREAK_UP_THRESHOLD=4
CHALLENGE_STREAK_DOWN_THRESHOLD=2

CHALLENGE_SESSION_QUESTION_TTL_SECONDS=21600

# Rank E starts at 0 by definition; override D-A thresholds only.
CHALLENGE_RANK_D_MIN=1000
CHALLENGE_RANK_C_MIN=3000
CHALLENGE_RANK_B_MIN=7000
CHALLENGE_RANK_A_MIN=15000

# --- Admin UIs ---
PGADMIN_EMAIL=admin@adaptiq.com
PGADMIN_PASSWORD=change_this_pgadmin_password
PGADMIN_MASTER_PASSWORD=change_this_pgadmin_master_password

# Challenge pre-generated ready queue targets
CHALLENGE_PREGEN_TARGET_PER_LEVEL=50
CHALLENGE_PREGEN_BATCH_SIZE=10
CHALLENGE_PREGEN_TOPUP_THRESHOLD=40

# Classic pre-generated ready queue targets
CLASSIC_PREGEN_TARGET_PER_BUCKET=50
CLASSIC_PREGEN_BATCH_SIZE=8
CLASSIC_PREGEN_TOPUP_THRESHOLD=40
