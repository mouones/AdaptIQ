# ─── Alternative Test Database Configuration (Reference-style credentials) ───────
# This uses SQLite for offline testing without requiring a running PostgreSQL server
# In production with Docker, replace with: postgresql+asyncpg://pfe:change_this_postgres_password@postgres:5432/adaptive_learning

# SQLite in-memory database for rapid testing (no persistence across runs)
DATABASE_URL=sqlite+aiosqlite:///:memory:

# Alternative: SQLite file-based database (persists between tests)
# Uncomment below to use persistent file instead of in-memory
# DATABASE_URL=sqlite+aiosqlite:///./test_adaptiq.db

# Redis (local fallback will be used if unavailable)
REDIS_URL=redis://localhost:6379

# Groq API Key
GROQ_API_KEY=

# App settings for testing
ENVIRONMENT=testing
LOG_LEVEL=INFO
AUTO_CREATE_TABLES=true

# JWT (testing)
JWT_SECRET_KEY=test_secret_key_minimum_32_characters_long_xxx
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin bootstrap key for testing
ADMIN_BOOTSTRAP_KEY=test_admin_bootstrap_key_12345

# CORS for local testing
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Note: To use with a real PostgreSQL server matching reference credentials:
# DATABASE_URL=postgresql+asyncpg://pfe:change_this_postgres_password@localhost:5432/adaptive_learning

